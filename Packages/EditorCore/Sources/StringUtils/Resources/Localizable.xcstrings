    "UnicodeNormalization.nfc.description": {
      "comment": "description for NFC",
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Canonical Decomposition, followed by Canonical Composition"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Décomposition canonique"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "正準等価によって分解し、正準等価によって合成"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "표준 분해를 하고 난 뒤 표준 합성"
          }
        }
      }
    },
