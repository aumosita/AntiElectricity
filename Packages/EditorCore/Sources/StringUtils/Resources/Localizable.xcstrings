    "UnicodeNormalization.nfkcCaseFold.description": {
      "comment": "description for NFKC case-fold",
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Applying NFKC, case folding, and removal of default-ignorable code points"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Application de NFKC, case folding et suppression des points de code ignorables."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "NFKCを適用しすべて小文字に変換（case folding）したのち、デフォルトの無視できるコードポイントを削除"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "NFKC"
          }
        }
      }
