    "UnicodeNormalization.modifiedNFC.description": {
      "comment": "description for Modified NFC",
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Unofficial NFC-based normalization form corresponding to Modified NFD"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Normalisation non officielle basée sur NFC, correspondant au NFD modifié"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "修正NFDに対応するNFCを基にした非公式の正規化形式"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "수정된 NFD에 대응되는 NFC 기반 비공식 정규화 형태"
          }
        }
      }
    },
