    "NSAppleEventsUsageDescription": {
      "comment": "Privacy - AppleEvents Sending Usage Description",
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "AntiElectricity needs your approval to control other applications with AppleScript."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "AntiElectricity a besoin de votre autorisation pour contrôler les autres applications avec AppleScript."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "AntiElectricityがAppleScriptでほかのアプリを操作するためにユーザの許可が必要です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "AntiElectricity가 AppleScript로 다른 응용 프로그램을 제어하려면 사용자 승인이 필요합니다."
          }
        }
      }
    },
