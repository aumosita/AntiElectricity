{
  "sourceLanguage": "en",
  "strings": {
    "%@ icon": {
      "comment": "%@ is application name",
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Icône %@"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "“%@”アイコン"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 아이콘"
          }
        }
      }
    },
    "About %@": {
      "comment": "%@ is app name",
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "À propos de %@"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@について"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@에 관하여"
          }
        }
      }
    },
    "and everyone who supports AntiElectricity!": {
      "comment": "last line of the Special Thanks section",
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "ainsi que tous ceux supportant AntiElectricity !"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "そしてAntiElectricityを支えてくれるすべての皆さま!"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "그리고 AntiElectricity를 응원해주시는 모든 분들!"
          }
        }
      }
    },
    "Code Contributors": {
      "comment": "section heading",
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Contributeurs du code"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コード貢献者"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "코드 기여자"
          }
        }
      }
    },
    "AntiElectricity is an open source program\nlicensed under the Apache License, Version 2.0.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "AntiElectricity est un programme open source\nsous licence Apache, version 2.0."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "AntiElectricityはオープンソースプログラムとして\nApache License, Version 2.0でライセンスされてます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "AntiElectricity는 오픈소스 프로그램이며,\nApache License, Version 2.0으로 보호됩니다."
          }
        }
      }
    },
    "AntiElectricity uses the following awesome technologies. We are deeply grateful for those who let us use their valuable work.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "AntiElectricity utilise les technologies géniales suivantes. Nous sommes très reconnaissants envers ceux nous permettant d’utiliser leurs précieux travaux."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "AntiElectricityは下記の素晴らしい技術を使用しています。有益な作品の公開に深く感謝いたします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "AntiElectricity는 다음과 같은 멋진 기술을 활용합니다. 가치있는 작업물을 사용할 수 있게 해주신 분들께 매우 감사드립니다."
          }
        }
      }
    },
    "Credits": {
      "comment": "button label",
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Crédits"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "クレジット"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기여자"
          }
        }
      }
    },
    "License": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Licence"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "利用許諾契約"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "사용권 계약"
          }
        }
      }
    },
    "Licenses": {
      "comment": "button label",
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Licences"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "利用許諾契約"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "사용권 계약"
          }
        }
      }
    },
    "Localization": {
      "comment": "section heading",
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Localisation"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ローカリゼーション"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "번역"
          }
        }
      }
    },
    "only on non-AppStore version": {
      "comment": "annotation for the Sparkle framework license",
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "uniquement la version non-AppStore"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "非AppStore版のみ"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "비 AppStore 버전에만 해당"
          }
        }
      }
    },
    "original developer": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "développeur original"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オリジナル開発者"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "원 개발자"
          }
        }
      }
    },
    "Special Thanks": {
      "comment": "section heading",
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Merci spécial"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "スペシャルサンクス"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "고마운 분들"
          }
        }
      }
    },
    "The AntiElectricity Project": {
      "comment": "section heading",
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le projet AntiElectricity"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "AntiElectricityプロジェクト"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "AntiElectricity 프로젝트"
          }
        }
      }
    },
    "Version %@ (%@)": {
      "comment": "%1$@ is version number and %2$@ is build number",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Version %1$@ (%2$@)"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Version %1$@ (%2$@)"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "バージョン %1$@ (%2$@)"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "버전 %1$@ (%2$@)"
          }
        }
      }
    }
  },
  "version": "1.0"
}