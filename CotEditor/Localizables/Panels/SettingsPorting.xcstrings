    "Choose a AntiElectricity settings archive to import.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Choisissez une archive de paramètres AntiElectricity à importer."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "読み込むAntiElectricity設定アーカイブを選択"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "가져올 AntiElectricity 설정 아카이브를 선택하십시오."
          }
        }
      }
    },
    "Error.versionMismatch.description": {
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "This settings archive was created by a different version of AntiElectricity (%@)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Cet archive de réglages a été créé par une autre version de AntiElectricity (%@)."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この設定アーカイブは、別のバージョンのAntiElectricity（%@）で作成されています。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 설정 아카이브는 다른 버전의 AntiElectricity에서 생성되었습니다. (%@)"
          }
        }
      }
    },
    "Error.versionMismatch.recoverySuggestion": {
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "You can still import these items, but some settings may be incompatible."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Vous pouvez toujours importer ces éléments, mais certains réglages peuvent être incompatibles."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "読み込むことはできますが、一部の設定は互換性がない場合があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 항목들을 가져올 수 있지만 일부 설정이 호환되지 않을 수 있습니다."
          }
        }
      }
    },
    "Export selected settings as an archive to allow importing into other computers.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Exporter les réglages sélectionnés sous forme d'archive afin de pouvoir les importer sur d'autres ordinateurs."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "選択した設定をアーカイブとして書き出して、他のコンピュータで読み込むことができます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "선택한 설정을 아카이브로 내보내 다른 컴퓨터로 가져올 수 있도록 합니다."
          }
        }
      }
    },
    "Export Settings": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Exporter les réglages"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "設定を書き出す"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "설정 내보내기"
          }
        }
      }
    },
    "Import Settings": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Importer les réglages"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "設定を読み込む"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "설정 가져오기"
          }
        }
      }
    },
    "Select the items to import:": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sélectionner les éléments à importer :"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "読み込む項目を選択:"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "가져올 항목 선택:"
          }
        }
      }
    },
