    "FileImporter.message": {
      "comment": "CotEditor Replace Definition is a proper file type name. Refer to InfoPlist.xcstrings.",
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Choose CotEditor Replace Definition or TSV (Tab-separated values) files."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Choisissez des fichiers de la liste de remplacements CotEditor ou des fichiers TSV (valeurs séparées par des tabulations)."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "CotEditor置換定義かTSV （タブ区切り値）ファイルを選択してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "CotEditor 대치 정의 또는 TSV(탭으로 분리된 값) 파일을 선택하십시오."
          }
        }
