            "state": "new",
            "value": "Allow ^ and $ to match the start and end of lines (multiline)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les caractères ^ et $ capturent respectivement le début et la fin d’une ligne."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "^と$がそれぞれ行頭と行末にも一致（複数行モード）"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "^와 $가 여러 줄에 걸쳐 일치할 수 있게 허용합니다."
          }
        }
      }
    },
