    "MonospacedFontAlert.message": {
      "comment": "“it” is the selected font in the title.",
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Do you want to use it for the monospaced font?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Voulez-vous l’utiliser comme police monochasse ?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "選択したフォントを等幅フォントとして使用しますか?"
