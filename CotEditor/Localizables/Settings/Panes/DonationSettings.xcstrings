{
  "sourceLanguage": "en",
  "strings": {
    "%lld cups": {
      "comment": "accessibility label for item quantity",
      "localizations": {
        "en": {
          "variations": {
            "plural": {
              "one": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%lld cup"
                }
              },
              "other": {
                "stringUnit": {
                  "state": "new",
                  "value": "%lld cups"
                }
              }
            }
          }
        },
        "fr": {
          "variations": {
            "plural": {
              "one": {
                "stringUnit": {
                  "state": "needs_review",
                  "value": "%lld tasse"
                }
              },
              "other": {
                "stringUnit": {
                  "state": "needs_review",
                  "value": "%lld tasses"
                }
              }
            }
          }
        },
        "ja": {
          "variations": {
            "plural": {
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%lld杯"
                }
              }
            }
          }
        },
        "ko": {
          "variations": {
            "plural": {
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%lld 컵"
                }
              }
            }
          }
        }
      }
    },
    "× %lld": {
      "comment": "multiple sign for the quantity of items to purchase",
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "× %lld"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "× %lld"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "× %lld"
          }
        }
      }
    },
    "An internet connection is required to donate.": {
      "comment": "error message",
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Une connexion Internet est requise pour faire un don."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "寄付にはインターネット接続が必要です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "후원하려면 인터넷 연결이 필요합니다."
          }
        }
      }
    },
    "As proof of your kind support, a coffee badge appears on the status bar during continuous support.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Comme preuve de votre soutien, un badge de café apparaît sur la barre d'état pendant le soutien continu."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "寛大なサポートの証として、継続的な寄付の期間中ステータスバーにコーヒーバッジが表示されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "후원에 보답하는 마음으로, 지속 후원을 해주시는 동안 상태 바에 커피 뱃지가 나타납니다."
          }
        }
      }
    },
    "Badge type:": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Type de badge :"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "バッジタイプ:"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "뱃지 타입:"
          }
        }
      }
    },
    "Continuous support": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Soutien continu"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "継続的なサポート"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "지속 후원"
          }
        }
      }
    },
    "AntiElectricity provides all features for free to everyone. You can support this project by offering coffee.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "AntiElectricity fournit toutes les fonctionnalités gratuitement à tout le monde. Vous pouvez soutenir ce projet en offrant du café."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "AntiElectricityはすべての人に無償ですべての機能を提供しています。コーヒーを送ることでこのプロジェクトをサポートすることができます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "AntiElectricity는 모든 기능을 무료로 제공합니다. 커피를 사주시면 프로젝트를 후원할 수 있습니다."
          }
        }
      }
    },
    "Donation is currently not available.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Le don n'est pas disponible pour le moment."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在、寄付はできません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "현재 후원 기능을 사용할 수 없습니다."
          }
        }
      }
    },
    "Manage Subscriptions": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gérer les abonnements"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サブスクリプションを管理"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "구독 관리"
          }
        }
      }
    },
    "One-time donation": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Don unique"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "1回限りの寄付"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "일회성 후원"
          }
        }
      }
    },
    "Open GitHub Sponsors": {
      "comment": "\"GitHub Sponsors\" is the name of a service by GitHub. Check the official localization.",
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Ouvrir GitHub Sponsors"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub Sponsorsを開く"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub Sponsors 열기"
          }
        }
      }
    },
    "Open in App Store": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ouvrir dans l’App Store"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "App Storeで開く"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "App Store에서 열기"
          }
        }
      }
    },
    "Privacy Policy": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Confidentialité"
          }
        },
        "ja": {
