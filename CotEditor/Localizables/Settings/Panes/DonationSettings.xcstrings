    "Restore Subscription": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rétablir l’abonnement"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サブスクリプションを復元"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "구독 복원"
          }
        }
      }
    },
    "Terms of Service": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Conditions de service"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サービス利用規約"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "서비스 약관"
          }
        }
      }
    },
    "The In-App donation feature is available only in AntiElectricity distributed in the App Store.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "La fonction de donation intégré n'est disponible que dans AntiElectricity distribué dans l'App Store."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アプリ内寄付機能はApp Storeで配布されているAntiElectricityでのみ有効です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "인앱 후원 기능은 App Store에서 배포된 AntiElectricity에서만 사용할 수 있습니다."
          }
        }
      }
    }
  },
  "version": "1.0"
