        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Block comment needs both begin and end delimiters."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les commentaires en bloc ont besoin d’un délimiteur de début et de fin."
          }
