          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "インタープリタは書類内の`#!`ヘッダからシンタックスを特定するときに使用されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "인터프리터는 문서의 `#!` 헤더에서 구문을 판별하는 데 사용됩니다."
          }
        }
      }
    },
