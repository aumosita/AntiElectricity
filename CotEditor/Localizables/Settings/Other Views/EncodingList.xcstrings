{
  "sourceLanguage": "en",
  "strings": {
    "Drag encodings to change the order:": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Faîtes glisser les encodages pour changer l’ordre :"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "エンコーディングをドラッグして並び替えてください:"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "인코딩을 드래그하여 순서 변경:"
          }
        }
      }
    },
    "EncodingListView.Model.RemovalError.defaultEncoding.description": {
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "The encoding set as default can’t be removed."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "L'encodage défini par défaut ne peut pas être supprimé."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デフォルトに設定されているエンコーディングは削除できません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기본 인코딩으로 설정된 항목은 삭제할 수 없습니다."
          }
        }
      }
    },
    "EncodingListView.Model.RemovalError.utf8.description": {
      "comment": "%@ is a localized encoding name.",
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%@ can’t be removed."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "%@ ne peut être supprimé."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@は削除できません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@은(는) 삭제할 수 없습니다."
          }
        }
      }
    },
    "Separator": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Séparateur"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "区切り線"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "구분 표시"
          }
        }
      }
    },
    "Text Encoding": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Encodage du texte"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "テキストエンコーディング"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "텍스트 인코딩"
          }
        }
      }
    },
    "This order is for the encoding menu and the encoding detection. The detection process only considers the items listed here, with higher items being prioritized.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Cet ordre est utilisé par le menu Encodage et par la détection de l’encodage à l’ouverture d’un fichier. Pour la détection, les encodages en haut de liste sont prioritaires."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この順序はエンコーディングメニューやエンコーディング判別で使われます。自動判別ではこのリストにあるもののみが考慮され、上位のエンコーディングがより優先して適用されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 순서는 인코딩 메뉴 및 인코딩 감지에 사용됩니다. 감지 과정에서는 여기에 나열된 항목만을 고려하며, 목록 상단에 있는 항목이 더 우선시됩니다."
          }
        }
      }
    }
  },
  "version": "1.0"
}