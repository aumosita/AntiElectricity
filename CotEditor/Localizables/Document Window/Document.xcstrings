    "Found %lld incompatible characters.": {
      "comment": "%lld is the number of characters.",
      "localizations": {
        "en": {
          "variations": {
            "plural": {
              "one": {
                "stringUnit": {
                  "state": "translated",
                  "value": "Found an incompatible character."
                }
              },
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "Found %lld incompatible characters."
                }
              }
            }
          }
        },
        "fr": {
          "variations": {
            "plural": {
              "one": {
                "stringUnit": {
                  "state": "translated",
                  "value": "Caractère incompatible trouvé."
                }
              },
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%lld caractères incompatibles trouvés."
                }
              }
            }
          }
        },
        "ja": {
          "variations": {
            "plural": {
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%lld個の非互換文字が見つかりました。"
                }
              }
            }
          }
        },
        "ko": {
          "variations": {
            "plural": {
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%lld개의 호환불가능한 문자를 발견함."
                }
              }
            }
          }
        }
      }
    },
    "Found %lld line endings other than %@.": {
      "comment": "%lld is the number of inconsistent line endings and %@ is a line ending type, such as LF",
      "localizations": {
        "en": {
          "variations": {
            "plural": {
              "one": {
                "stringUnit": {
                  "state": "translated",
                  "value": "Found a line ending other than %2$@."
                }
              },
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "Found %1$lld line endings other than %2$@."
                }
              }
            }
          }
        },
        "fr": {
          "variations": {
            "plural": {
              "one": {
                "stringUnit": {
                  "state": "translated",
                  "value": "Fin de ligne autre que %2$@ trouvée."
                }
              },
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%1$lld fins de ligne autres que %2$@ trouvées."
                }
              }
            }
          }
        },
        "ja": {
          "variations": {
            "plural": {
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%1$lld個の%2$@でない改行コードが見つかりました。"
                }
              }
            }
          }
        },
        "ko": {
          "variations": {
            "plural": {
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "%2$@가 아닌 줄바꿈 %1$lld을(를) 발견함."
                }
              }
            }
          }
        }
      }
    },
