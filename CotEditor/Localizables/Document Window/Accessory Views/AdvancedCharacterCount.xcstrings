{
  "sourceLanguage": "en",
  "strings": {
    "*%lld* character(s)": {
      "comment": "counter for advanced character count",
      "localizations": {
        "en": {
          "variations": {
            "plural": {
              "one": {
                "stringUnit": {
                  "state": "translated",
                  "value": "*%lld* character"
                }
              },
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "*%lld* characters"
                }
              }
            }
          }
        },
        "fr": {
          "variations": {
            "plural": {
              "one": {
                "stringUnit": {
                  "state": "translated",
                  "value": "*%lld* caractère"
                }
              },
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "*%lld* caractères"
                }
              },
              "zero": {
                "stringUnit": {
                  "state": "translated",
                  "value": "*%lld* caractère"
                }
              }
            }
          }
        },
        "ja": {
          "variations": {
            "plural": {
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "*%lld*文字"
                }
              }
            }
          }
        },
        "ko": {
          "variations": {
            "plural": {
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "*%lld* 문자"
                }
              }
            }
          }
        }
      }
    },
    "Advanced Character Count…": {
      "comment": "menu item",
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Comptage de caractères avancé…"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "高度な文字カウント…"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "고급 문자 개수…"
          }
        }
      }
    },
    "CharacterUnit.byte.description": {
      "comment": "description for byte",
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Count bytes of the text encoded with the specified encoding."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Compter les bytes de texte encodé selon l’encodage spécifié."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "指定したエンコーディングでエンコードしたときのバイト長をカウントします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "특정한 인코딩으로 인코딩된 텍스트의 바이트를 셉니다."
          }
        }
      }
    },
    "CharacterUnit.byte.label": {
      "comment": "count unit",
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Byte"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Byte"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "バイト"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "바이트"
          }
        }
      }
    },
    "CharacterUnit.graphemeCluster.description": {
      "comment": "description for grapheme cluster",
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Count in the intuitive way defined in Unicode. A character consisting of multiple Unicode code points, such as emojis, is counted as one character."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Comptage intuitif tel que défini par Unicode. Un caractère comprenant plusieurs points de code Unicode, par exemple un emoji, sont comptés comme un seul caractère."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Unicodeで定義されている人の感覚に近い単位でカウントします。絵文字など複数のUnicodeコードポイントから成る文字も1文字で数えます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "유니코드에서"
          }
        }
      }
    },
    "CharacterUnit.graphemeCluster.label": {
      "comment": "count unit (technical term defined in Unicode)",
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Grapheme cluster"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Grapheme cluster"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "書記素クラスタ"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Grapheme cluster"
          }
        }
      }
    },
    "CharacterUnit.unicodeScalar.description": {
      "comment": "description for unicode scalar",
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Count Unicode code points. Same as counting UTF-32."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Count Unicode code points. Same as counting UTF-32."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Unicodeコードポイント単位でカウントします。UTF-32のカウントと同一です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "유니코드 코드 포인트를 셉니다. UTF-32를 세는 것과 같습니다."
          }
        }
      }
    },
    "CharacterUnit.unicodeScalar.label": {
      "comment": "count unit",
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Unicode scalar"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Scalaire Unicode"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Unicodeスカラー"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "유니코드 스칼라"
          }
        }
      }
    },
    "CharacterUnit.utf16.description": {
      "comment": "description for UTF-16",
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Count Unicode code points but a surrogate pair as two characters."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Compter les points de code Unicode, mais les paires de caractères de substitution comme deux caractères."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Unicodeコードポイント単位でカウントしますがサロゲートペアは2文字でカウントします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "유니코드 코드 포인트를 세지만 대행 코드를 문자 두 개로 셉니다."
          }
        }
      }
    },
    "CharacterUnit.utf16.label": {
      "comment": "count unit",
      "extractionState": "extracted_with_value",
      "localizations": {
