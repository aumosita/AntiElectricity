    "UnsavedReinterpretationAlert.informativeText": {
      "comment": "%@ is an encoding name",
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Are you sure you want to discard your changes and reopen the document using “%@”?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Voulez-vous vraiment abandonner les modifications et réouvrir le document en utilisant « %@ » ?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "変更を破棄して、“%@”で書類を開き直してもよろしいですか?"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "정말 저장하지 않은 변경 사항을 복귀하고 문서를 ‘%@’을(를) 이용해서 다시 여시겠습니까?"
          }
        }
      }
    },
