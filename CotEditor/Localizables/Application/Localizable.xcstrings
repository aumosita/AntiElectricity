    "IssueReport.description": {
      "comment": "%1$@ is a link to a web page and %2$@ is an e-mail",
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Fill in the following template, then post it on %1$@ or send it to %2$@. Please note that the content of your email may be shared on the Issue page. Please write your message in either English or Japanese."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Remplis le modèle ci-dessous, puis publie-le sur %1$@ ou envoie-le à %2$@. Note que le contenu de ton e-mail peut être partagé sur la page des issues. Rédige ton message en anglais ou en japonais."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "以下のテンプレートに記入して%1$@に投稿するか%2$@にメールを送ってください。送られたメールの内容はIssueページで公開される可能があります。本文は英語か日本語、どちらかでお書きください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다음 양식을 채워, %1$@에 게시하거나 %2$@로 보내십시오. 이메일로 전송한 내용이 Issue 페이지에서 공개적으로 공유될 수 있음에 주의하세요. 내용을 영어 또는 일본어로 작성해주시길 바랍니다."
          }
        }
      }
    },
