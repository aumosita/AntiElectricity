    "DirectoryDocumentError.alreadyOpen.recoverySuggestion": {
      "comment": "“it” is the file in description.",
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "To open it in this window, close the existing window first."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Pour l'ouvrir dans cette fenêtre, il faut d'abord fermer la fenêtre existante."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このウインドウで開くには、先にすでにあるウインドウを閉じてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 윈도우에서 열려면, 존재하는 윈도우를 먼저 닫으십시오."
          }
        }
      }
    },
    "DocumentClosingAlert.button.dontSave": {
      "comment": "Refer the same sentence in AppKit.framework by Apple.",
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Don’t Save"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ne pas enregistrer"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "保存しない"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "저장하지 않음"
          }
        }
      }
    },
    "DocumentClosingAlert.lossyEncoding.informativeText": {
      "comment": "For the first sentence, refer the same sentence in AppKit.framework by Apple. For the latter one, refer the DocumentSavingAlert.lossyEncoding.recoverySuggestion.",
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Your changes will be lost if you don’t save them. Incompatible characters are either substituted or removed in saving."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vos modifications seront perdues si vous ne les enregistrez pas. Les caractères incompatibles sont soit remplacés, soit supprimés lors de l’enregistrement."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "保存しないと、変更内容は失われます。互換性のない文字は保存時に代替または削除されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "저장하지 않으면 변경 사항이 유실됩니다. 호환되지 않는 문자는 저장하면 대체되거나 삭제됩니다."
          }
        }
      }
    },
    "DocumentClosingAlert.message": {
      "comment": "Refer the same sentence in AppKit.framework by Apple.",
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Do you want to save the changes made to the document “%@”?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Souhaitez-vous enregistrer les modifications apportées au document « %@ » ?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "書類“%@”に加えた変更を保存しますか?"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "‘%@’ 문서의 변경 사항을 저장하겠습니까?"
          }
        }
      }
    },
