    "LossyEncodingError.recoverySuggestion": {
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Incompatible characters are either substituted or removed in saving. Do you want to change the text encoding and review the incompatible characters?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les caractères incompatibles sont soit remplacés, soit supprimés lors de l’enregistrement. Voulez-vous modifier l’encodage du texte et revoir les caractères incompatibles ?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "互換性のない文字は保存時に代替または削除されます。エンコーディングを変更し非互換文字を確認しますか?"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "호환되지 않는 문자는 저장하면 대체되거나 삭제됩니다. 텍스트 인코딩을 변경하고 호환되지 않는 문자를 검토하시겠습니까?"
          }
        }
      }
