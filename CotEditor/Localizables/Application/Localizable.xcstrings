    "DocumentSavingError.lossyEncoding.recoverySuggestion": {
      "comment": "“save anyway” is the standard phrase in macOS. Refer the Apple's translation.",
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Incompatible characters are either substituted or removed in saving. Do you want to save anyway?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les caractères incompatibles sont soit remplacés, soit supprimés lors de l’enregistrement. Voulez-vous quand même enregistrer ?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "互換性のない文字は保存時に代替または削除されます。それでも保存しますか?"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
