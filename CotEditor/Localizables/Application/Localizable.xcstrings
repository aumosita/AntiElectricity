    "UpdatedByExternalProcessAlert.informativeText": {
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Do you want to keep AntiElectricity’s version or update it to the modified version?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Voulez-vous garder la version dans AntiElectricity ou rafraîchir vers la version modifiée ?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "AntiElectricityでの編集内容を保持しますか、それとも変更された内容に更新しますか?"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "AntiElectricity에 열린 상태를 유지하시겠습니까, 또는 수정된 상태로 업데이트하시겠습니까?"
          }
