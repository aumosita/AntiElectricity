{
  "sourceLanguage": "en",
  "strings": {
    " (%@)": {
      "comment": "general format for additional string in parentheses following other string (Note that there is a space before the parentheses. In some languages, this space should be removed.)",
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": " (%@)"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "（%@）"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": " (%@)"
          }
        }
      }
    },
    "%@:": {
      "comment": "format for control labels followed by a colon",
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ :"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@:"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@:"
          }
        }
      }
    },
    "%@: %@": {
      "comment": "set of label and value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@: %2$@"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ : %2$@"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@: %2$@"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@: %2$@"
          }
        }
      }
    },
