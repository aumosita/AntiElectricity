    "5Ey-vx-5Sm.title": {
      "comment": "Class = \"NSTextFieldCell\"; title = \"Perform replacement using these rules in succession from the top down:\"; ObjectID = \"5Ey-vx-5Sm\";",
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Perform replacement using these rules in succession from the top down:"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Remplacer le texte en appliquant ces règles successivement, du haut vers le bas :"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "以下の条件を上から順に適用して置換:"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다음 규칙을 위에서부터 아래로 연속해서 적용하며 대치를 수행합니다."
          }
        }
      }
    },
    "99C-Bz-ySi.ibShadowedToolTip": {
      "comment": "Class = \"NSButton\"; ibShadowedToolTip = \"Highlight all matches of the replacement rules.\"; ObjectID = \"99C-Bz-ySi\";",
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Highlight all matches of the replacement rules."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mettre en surbrillance toutes les correspondances des règles de remplacement."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すべての置換条件の一致をハイライト"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "대치 규칙의 모든 일치를 강조합니다."
          }
        }
      }
    },
